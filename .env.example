# ────────────────────────────────────────────────────────────
# Vi-Slides Lite — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is read by the server at startup.
# ────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# Your PostgreSQL connection string.
# Format: postgresql://user:password@host:port/database
#
# Local PostgreSQL example:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vi_slides
#
# Supabase, Neon, Railway, etc. will give you this URL.
DATABASE_URL=postgresql://user:password@localhost:5432/vi_slides

# ── Authentication ───────────────────────────────────────────
# Secret key used to sign JWT tokens.
# Use a long random string — treat it like a password.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-string

# ── AI (optional) ────────────────────────────────────────────
# Without this, AI features are disabled but the app still works.
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ── Server ───────────────────────────────────────────────────
# Port the Express backend listens on (default: 5000)
PORT=5000

# URL the React frontend runs on (used for CORS)
CLIENT_URL=http://localhost:3000
